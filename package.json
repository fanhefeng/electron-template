{
  "name": "electron-template",
  "version": "1.0.0",
  "description": "Electron template with Vite, React, TypeScript",
  "main": "dist/main/main/main.js",
  "author": "fhf",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:watch:shared\" \"npm:sync:shared:watch\" \"npm:watch:main\" \"npm:watch:preload\" \"npm:dev:renderer\" \"npm:start\"",
    "watch:shared": "tsc -p tsconfig.shared.json -w",
    "sync:shared": "node scripts/sync-shared.cjs",
    "sync:shared:watch": "node scripts/sync-shared.cjs --watch",
    "watch:main": "tsc -p tsconfig.main.json -w",
    "watch:preload": "esbuild src/preload/mainPreload.ts src/preload/settingsPreload.ts src/preload/aboutPreload.ts --bundle --platform=node --outdir=dist/preload/preload --external:electron --format=cjs --watch",
    "dev:renderer": "vite",
    "start": "wait-on tcp:5173 dist/main/main/main.js dist/preload/preload/mainPreload.js && electron .",
    "clean": "node -e \"const fs=require('fs');const paths=['dist','dist_electron','tsconfig.main.tsbuildinfo','tsconfig.preload.tsbuildinfo','tsconfig.renderer.tsbuildinfo','tsconfig.shared.tsbuildinfo'];paths.forEach(p=>{if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});});\"",
    "build": "npm run clean && npm run build:shared && npm run build:main && npm run build:preload && npm run sync:shared && npm run build:renderer",
    "build:shared": "tsc -p tsconfig.shared.json",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "esbuild src/preload/mainPreload.ts src/preload/settingsPreload.ts src/preload/aboutPreload.ts --bundle --platform=node --outdir=dist/preload/preload --external:electron --format=cjs",
    "build:renderer": "vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && electron-builder",
    "deploy-update": "node scripts/deploy-update.js",
    "package-and-deploy": "npm run package && npm run deploy-update",
    "start-update-server": "cd updater-server && npm install && npm start"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.2.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.example.electrontemplate",
    "productName": "ElectronTemplate",
    "directories": {
      "output": "dist_electron",
      "buildResources": "resources"
    },
    "extraResources": [
      {
        "from": "resources/fonts",
        "to": "fonts"
      }
    ],
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*"
    ],
    "publish": {
      "provider": "generic",
      "url": "http://localhost:8080/updates"
    },
    "protocols": [
      {
        "name": "ElectronTemplate",
        "schemes": ["electrontemplate"]
      }
    ],
    "mac": {
      "icon": "resources/icons/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "signIgnore": []
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
