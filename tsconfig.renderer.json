{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/renderer",
    "rootDir": "src",
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "composite": true
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"],
  "exclude": ["node_modules"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
